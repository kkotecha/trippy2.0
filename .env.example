OPENAI_API_KEY=your_openai_api_key_here

# Arize AX Cloud (optional - for cloud-based observability)
# Leave empty to use local Phoenix
# Get these from: https://app.arize.com/ → Settings → API Keys
# Use SERVICE KEY (not user key) for application integration
ARIZE_SPACE_ID=your_arize_space_id_here
ARIZE_API_KEY=your_arize_service_key_here
ARIZE_PROJECT_NAME=trip-planner